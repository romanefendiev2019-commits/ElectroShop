<Page x:Class="ElectroShop.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AuthorizationPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая промо-зона -->
        <Grid Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <StackPanel VerticalAlignment="Center" Margin="70,0,70,0">
                <TextBlock Text="ElectroShop"
                           FontSize="46"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextMainBrush}"/>
                <TextBlock Text="Техника для работы, игр и повседневной жизни"
                           FontSize="20"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,18,0,0"
                           TextWrapping="Wrap"/>
                <Border Margin="0,35,0,0"
                        Background="{StaticResource SurfaceBrush2}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="• Смартфоны, ноутбуки, мониторы, периферия"
                                   Foreground="{StaticResource TextMainBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Удобный каталог, корзина, история заказов"
                                   Foreground="{StaticResource TextMainBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="• Электронные чеки и QR-коды"
                                   Foreground="{StaticResource TextMainBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Правая форма -->
        <Grid Grid.Column="1">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="390"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Вход"
                               Style="{StaticResource PageTitleStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Авторизуйтесь для продолжения"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,22"/>

                    <TextBlock Text="Логин"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtLogin"
                             Style="{StaticResource MainTextBoxStyle}"
                             MaxLength="50"/>

                    <TextBlock Text="Пароль"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource MainPasswordBoxStyle}"
                                 MaxLength="50"/>

                    <Button x:Name="btnLogin"
                            Content="Войти"
                            Style="{StaticResource MainButtonStyle}"
                            Margin="0,10,0,8"
                            Click="btnLogin_Click"/>

                    <Button x:Name="btnReg"
                            Content="Регистрация"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnReg_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>