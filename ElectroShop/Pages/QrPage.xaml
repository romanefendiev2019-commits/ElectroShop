<Page x:Class="ElectroShop.Pages.QrPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="QrPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Border Style="{StaticResource CardBorderStyle}"
                Width="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Связь с магазином"
                           Style="{StaticResource PageTitleStyle}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Отсканируйте QR-код или перейдите по ссылке"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,24"/>

                <Border Background="{StaticResource SurfaceBrush2}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16">
                    <Image x:Name="imgQr"
                           Width="260"
                           Height="260"
                           Stretch="Uniform"/>
                </Border>

                <TextBlock x:Name="tbTelegramLink"
                           Text="Ссылка"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="16"
                           Margin="0,18,0,18"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="btnOpenTelegram"
                            Content="Открыть Telegram"
                            Width="170"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnOpenTelegram_Click"/>

                    <Button x:Name="btnBack"
                            Content="Назад"
                            Width="110"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnBack_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>