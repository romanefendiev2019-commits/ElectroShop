<Page x:Class="ElectroShop.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddEditProductPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="tbTitle"
                       Text="Товар"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="100"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка -->
                <StackPanel Grid.Column="0">

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Основные данные"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Название товара" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtName" Style="{StaticResource MainTextBoxStyle}" MaxLength="150"/>

                            <TextBlock Text="Модель" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtModel" Style="{StaticResource MainTextBoxStyle}" MaxLength="100"/>

                            <TextBlock Text="Описание" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtDescription"
                                     Style="{StaticResource MainTextBoxStyle}"
                                     Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MaxLength="1000"/>

                            <TextBlock Text="Характеристики" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtSpecifications"
                                     Style="{StaticResource MainTextBoxStyle}"
                                     Height="110"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MaxLength="1000"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Параметры"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Цена" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtPrice" Style="{StaticResource MainTextBoxStyle}" MaxLength="10"/>

                            <TextBlock Text="Количество" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtQuantity" Style="{StaticResource MainTextBoxStyle}" MaxLength="6"/>

                            <TextBlock Text="Гарантия (мес.)" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBox x:Name="txtWarranty" Style="{StaticResource MainTextBoxStyle}" MaxLength="3"/>

                            <CheckBox x:Name="chkIsPortable"
                                      Content="Портативное устройство"
                                      Foreground="{StaticResource TextMainBrush}"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Правая колонка -->
                <StackPanel Grid.Column="1">

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Справочники"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Категория" Foreground="{StaticResource TextMainBrush}"/>
                            <Grid Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="cmbCategory"
                                          Grid.Column="0"
                                          Style="{StaticResource MainComboBoxStyle}"
                                          Margin="0,0,10,0"/>

                                <Button x:Name="btnAddCategory"
                                        Grid.Column="1"
                                        Content="+ Категория"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="btnAddCategory_Click"/>
                            </Grid>

                            <TextBlock Text="Бренд" Foreground="{StaticResource TextMainBrush}"/>
                            <Grid Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="cmbBrand"
                                          Grid.Column="0"
                                          Style="{StaticResource MainComboBoxStyle}"
                                          Margin="0,0,10,0"/>

                                <Button x:Name="btnAddBrand"
                                        Grid.Column="1"
                                        Content="+ Бренд"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Click="btnAddBrand_Click"/>
                            </Grid>

                            <TextBlock Text="Статус" Foreground="{StaticResource TextMainBrush}"/>
                            <ComboBox x:Name="cmbStatus"
                                      Style="{StaticResource MainComboBoxStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Основное изображение"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <TextBox x:Name="txtImage"
                                     Style="{StaticResource MainTextBoxStyle}"
                                     IsReadOnly="True"/>

                            <Button x:Name="btnChooseImage"
                                    Content="Выбрать изображение"
                                    Style="{StaticResource MainButtonStyle}"
                                    Margin="0,0,0,12"
                                    Click="btnChooseImage_Click"/>

                            <Border Background="{StaticResource SurfaceBrush2}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Image x:Name="imgPreview"
                                       Height="180"
                                       Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Дополнительные изображения"
                                       Foreground="{StaticResource TextMainBrush}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <ListBox x:Name="lbAdditionalImages"
                                     Height="120"
                                     Margin="0,0,0,12"/>

                            <Button x:Name="btnAddAdditionalImage"
                                    Content="Добавить изображение"
                                    Style="{StaticResource MainButtonStyle}"
                                    Click="btnAddAdditionalImage_Click"/>

                            <Button x:Name="btnRemoveAdditionalImage"
                                    Content="Удалить выбранное"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,10,0,0"
                                    Click="btnRemoveAdditionalImage_Click"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnSave"
                            Content="Сохранить"
                            Style="{StaticResource MainButtonStyle}"
                            Height="42"
                            Margin="6,8,6,6"
                            Click="btnSave_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>