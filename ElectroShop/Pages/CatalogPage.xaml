<Page x:Class="ElectroShop.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CatalogPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левый сайдбар -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">

                    <TextBlock Text="ElectroShop"
                               Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock x:Name="tbWelcome"
                               Text="Добро пожаловать"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="tbRole"
                               Text="Роль:"
                               Margin="0,8,0,20"
                               Foreground="{StaticResource TextMutedBrush}"/>

                    <TextBlock Text="Поиск"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtSearch"
                             Style="{StaticResource MainTextBoxStyle}"
                             TextChanged="txtSearch_TextChanged"/>

                    <TextBlock Text="Категория"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <ComboBox x:Name="cmbCategory"
                              Style="{StaticResource MainComboBoxStyle}"
                              SelectionChanged="cmbCategory_SelectionChanged"/>

                    <TextBlock Text="Сортировка"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <ComboBox x:Name="cmbSort"
                              Style="{StaticResource MainComboBoxStyle}"
                              SelectionChanged="cmbSort_SelectionChanged"/>

                    <Separator Margin="0,10,0,10"/>

                    <Button x:Name="btnProfile"
                            Content="Профиль"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnProfile_Click"/>

                    <Button x:Name="btnCart"
                            Content="Корзина"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnCart_Click"/>

                    <Button x:Name="btnQr"
                            Content="QR / Telegram"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnQr_Click"/>

                    <Button x:Name="btnAdmin"
                            Content="Админ-панель"
                            Style="{StaticResource GhostButtonStyle}"
                            Visibility="Collapsed"
                            Click="btnAdmin_Click"/>

                    <Button x:Name="btnExit"
                            Content="Выйти"
                            Style="{StaticResource DangerButtonStyle}"
                            Margin="0,16,0,0"
                            Click="btnExit_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Правая часть -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Каталог товаров"
                           Style="{StaticResource PageTitleStyle}"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Style="{StaticResource CardBorderStyle}"
                        Padding="10"
                        Height="42"
                        VerticalAlignment="Center">
                    <TextBlock Text="Электроника и аксессуары"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- ВАЖНО: тут теперь ItemsControl, а не ListView -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <ItemsControl x:Name="lvProducts">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="420"
                                       Margin="0,0,0,20"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}"
                                    Width="400"
                                    Height="245">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="125"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Картинка -->
                                    <Border Grid.Column="0"
                                            Background="{StaticResource SurfaceBrush2}"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Margin="0,0,14,0">
                                        <Image Source="{Binding ImagePath}"
                                               Width="100"
                                               Height="100"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Контент -->
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="56"/>
                                            <RowDefinition Height="26"/>
                                            <RowDefinition Height="34"/>
                                            <RowDefinition Height="54"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding ProductName}"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="52"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Model, StringFormat=Модель: {0}}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="13"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding ShortSpecifications}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,10,0,0"
                                                   MaxHeight="48"/>

                                        <Grid Grid.Row="4" Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="В корзину"
                                                    Tag="{Binding SourceProduct}"
                                                    Margin="20,0,0,5"
                                                    Height="38"
                                                    MinWidth="120"
                                                    Style="{StaticResource MainButtonStyle}"
                                                    Click="btnAddToCart_Click"/>

                                            <Button Grid.Column="2"
                                                    Content="Подробнее"
                                                    Tag="{Binding SourceProduct}"
                                                    Margin="20,0,0,5"
                                                    Height="38"
                                                    MinWidth="120"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Click="btnDetails_Click"/>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>