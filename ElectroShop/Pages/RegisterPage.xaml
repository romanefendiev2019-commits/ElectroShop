<Page x:Class="ElectroShop.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegisterPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.1*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Grid Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <StackPanel VerticalAlignment="Center" Margin="60,0,60,0">
                <TextBlock Text="Создание аккаунта"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextMainBrush}"/>
                <TextBlock Text="Получите доступ к каталогу, корзине, заказам и электронным чекам."
                           Margin="0,16,0,0"
                           FontSize="18"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Форма -->
        <Grid Grid.Column="1">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="440"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               Style="{StaticResource PageTitleStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Введите данные нового пользователя"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,22"/>

                    <TextBlock Text="Имя"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtName"
                             Style="{StaticResource MainTextBoxStyle}"
                             MaxLength="100"/>

                    <TextBlock Text="Логин"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtLogin"
                             Style="{StaticResource MainTextBoxStyle}"
                             MaxLength="50"/>

                    <TextBlock Text="Пароль"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource MainPasswordBoxStyle}"
                                 MaxLength="50"/>

                    <TextBlock Text="Повтор пароля"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <PasswordBox x:Name="txtPasswordRepeat"
                                 Style="{StaticResource MainPasswordBoxStyle}"
                                 MaxLength="50"/>

                    <TextBlock Text="Email"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtEmail"
                             Style="{StaticResource MainTextBoxStyle}"
                             MaxLength="100"/>

                    <TextBlock Text="Телефон"
                               Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtPhone"
                             Style="{StaticResource MainTextBoxStyle}"
                             MaxLength="20"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button x:Name="btnRegister"
                                Content="Зарегистрироваться"
                                Width="180"
                                Style="{StaticResource MainButtonStyle}"
                                Margin="0,0,10,0"
                                Click="btnRegister_Click"/>

                        <Button x:Name="btnBack"
                                Content="Назад"
                                Width="110"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="btnBack_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>