<Page x:Class="ElectroShop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProfilePage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="190"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Личный кабинет"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="100"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush2}"
                        CornerRadius="14"
                        Margin="0,0,16,0">
                    <TextBlock Text="👤"
                               FontSize="58"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="tbFullName"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="tbLogin"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,10,0,0"/>
                    <TextBlock x:Name="tbEmail"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,8,0,0"/>
                    <TextBlock x:Name="tbPhone"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,8,0,0"/>
                    <TextBlock x:Name="tbCreatedAt"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="История заказов"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <ListView x:Name="lvOrders"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,10,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush2}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="4"
                                        Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding OrderID, StringFormat={}Заказ #{0}}"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OrderDate, StringFormat={}{0}}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalAmount, StringFormat={}{0} ₽}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding OrderStatuses.StatusName}"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Электронные чеки"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <ListView x:Name="lvReceipts"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,10,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush2}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="4"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ReceiptID, StringFormat={}Чек #{0}}"
                                                   Foreground="{StaticResource TextMainBrush}"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat={}{0}}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,6,0,0"/>
                                        <Button Content="Открыть"
                                                Tag="{Binding}"
                                                Width="110"
                                                Margin="0,10,0,0"
                                                Style="{StaticResource MainButtonStyle}"
                                                Click="btnOpenReceipt_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>