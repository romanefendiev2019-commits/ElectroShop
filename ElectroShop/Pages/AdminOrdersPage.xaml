<Page x:Class="ElectroShop.Pages.AdminOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminOrdersPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="16">
                <TextBlock Text="Orders"
                           Style="{StaticResource PageTitleStyle}"/>

                <TextBlock Text="Управление заказами"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,10,0,22"/>

                <Button x:Name="btnConfirm"
                        Content="Подтвердить"
                        Style="{StaticResource MainButtonStyle}"
                        Click="btnConfirm_Click"/>

                <Button x:Name="btnComplete"
                        Content="Выдать"
                        Style="{StaticResource GhostButtonStyle}"
                        Click="btnComplete_Click"/>

                <Button x:Name="btnCancelOrder"
                        Content="Отменить"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="btnCancelOrder_Click"/>

                <Button x:Name="btnBack"
                        Content="Назад"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0,24,0,0"
                        Click="btnBack_Click"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Список заказов"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>

            <ListView x:Name="lvOrders"
                      Grid.Row="1"
                      Background="Transparent"
                      BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding OrderID, StringFormat={}#{0}}"
                                           Foreground="{StaticResource TextMainBrush}"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Users.FullName}"
                                           Foreground="{StaticResource TextMainBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding OrderDate, StringFormat={}{0}}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding TotalAmount, StringFormat={}{0} ₽}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding OrderStatuses.StatusName}"
                                           Foreground="{StaticResource TextMainBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>